{
  "name": "GHS VEX PROS + LemLib",
  "image": "ubuntu:22.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {}
  },
  "overrideCommand": true,
  "containerEnv": {
    "PATH": "${containerEnv:PATH}:${homeFolder}/.local/bin"
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "sigbots.pros",
        "ms-vscode.cpptools"
      ]
    }
  }
}
